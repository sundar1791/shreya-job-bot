# ─────────────────────────────────────────────────────────────────
# Job Bot — Environment Variables
# Copy this file to .env and fill in your real values.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────

# ── JSearch API (via RapidAPI) ─────────────────────────────────
# 1. Create a free account at https://rapidapi.com/
# 2. Subscribe to the JSearch API: https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
# 3. Copy your RapidAPI key from the API playground
JSEARCH_API_KEY=your_rapidapi_key_here

# ── SerpAPI (Google Jobs fallback) ─────────────────────────────
# Only used when the three primary APIs return too few jobs (rate-limited etc).
# Get a free key at https://serpapi.com (250 searches/month free).
# Safe to leave blank — the bot will simply skip the fallback.
SERPAPI_KEY=your_serpapi_key_here

# ── Anthropic API (LLM ranking) ────────────────────────────────
# Get your key at: https://console.anthropic.com/
# If omitted, the bot falls back to keyword-based scoring.
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Gmail SMTP ─────────────────────────────────────────────────
# Use an App Password (NOT your regular Gmail password).
# How to create: Google Account → Security → 2-Step Verification → App passwords
GMAIL_USER=your_gmail_address@gmail.com
GMAIL_APP_PASS=your_16_character_app_password

# ── Email addresses ────────────────────────────────────────────
FROM_EMAIL=your_gmail_address@gmail.com
TO_EMAIL=shreyaa1693@gmail.com
