# ─────────────────────────────────────────────────────────────────
# Job Bot — Environment Variables
# Copy this file to .env and fill in your real values.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────

# ── Apify (LinkedIn job scraping) ──────────────────────────────
# Get your token at: https://console.apify.com/account/integrations
# The bot uses the "bebity/linkedin-jobs-scraper" actor.
# Apify offers a free tier with a monthly usage credit.
APIFY_TOKEN=your_apify_api_token_here

# ── Anthropic API (LLM ranking) ────────────────────────────────
# Get your key at: https://console.anthropic.com/
# If omitted, the bot falls back to keyword-based scoring.
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Gmail SMTP ─────────────────────────────────────────────────
# Use an App Password (NOT your regular Gmail password).
# How to create: Google Account → Security → 2-Step Verification → App passwords
GMAIL_USER=your_gmail_address@gmail.com
GMAIL_APP_PASS=your_16_character_app_password

# ── Email addresses ────────────────────────────────────────────
FROM_EMAIL=your_gmail_address@gmail.com
TO_EMAIL=shreyaa1693@gmail.com
